{
  "name": "sakura-push",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/index.js --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.10.0",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.10",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "~5.5.0"
  }
}
